{
  "name": "npm-provenance-checker",
  "version": "0.1.1",
  "description": "Batch-verify npm provenance attestations across your project's lockfile. CLI + GitHub Action.",
  "keywords": [
    "npm",
    "provenance",
    "attestation",
    "slsa",
    "supply-chain",
    "security",
    "cli",
    "github-action",
    "lockfile",
    "audit"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mattschaller/npm-provenance-checker"
  },
  "author": "Matthew Schaller <matt@mattschaller.com>",
  "type": "module",
  "bin": {
    "npm-provenance-checker": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "action.yml"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
